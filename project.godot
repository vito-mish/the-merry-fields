; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="The Merry Fields"
config/description="A cozy farming RPG"
config/version="0.1.0"
run/main_scene="res://scenes/maps/farm.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

TransitionManager="*res://scripts/managers/transition_manager.gd"
TimeManager="*res://scripts/managers/time_manager.gd"
EconomyManager="*res://scripts/managers/economy_manager.gd"
LocaleManager="*res://scripts/managers/locale_manager.gd"
DebugPanel="*res://scripts/debug/debug_panel.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

